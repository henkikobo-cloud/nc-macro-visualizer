{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/nc-macro-visualizer/schemas/beginner_flow.schema.json",
  "title": "NC Macro Visualizer Beginner Flow",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "source_name",
    "nodes",
    "edges",
    "warnings"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "beginner-flow/v0.2"
    },
    "source_name": {
      "type": "string"
    },
    "nodes": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/node"
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/edge"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/warning"
      }
    }
  },
  "$defs": {
    "node": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "title",
        "summary",
        "source_line_no",
        "source_label",
        "source_text"
      ],
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "kind": {
          "type": "string",
          "enum": [
            "start",
            "end",
            "process",
            "decision",
            "call",
            "machine_action",
            "needs_confirmation",
            "warning",
            "jump_out",
            "jump_in"
          ]
        },
        "title": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "source_line_no": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "source_label": {
          "type": [
            "string",
            "null"
          ]
        },
        "source_text": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "edge": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source",
        "target",
        "label",
        "kind"
      ],
      "properties": {
        "source": {
          "type": "string",
          "minLength": 1
        },
        "target": {
          "type": "string",
          "minLength": 1
        },
        "label": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": [
            "sequential",
            "branch_true",
            "branch_false",
            "jump",
            "loop_body",
            "loop_exit",
            "call"
          ]
        }
      }
    },
    "warning": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_line_no",
        "code",
        "message"
      ],
      "properties": {
        "source_line_no": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    }
  }
}
